{
    "version": 2,
    "builds": [
        {
            "src": "**/*.php",
            "use": "@vercel/php"
        }
    ],
    "routes": [
        {
            "src": "/",
            "dest": "/index.php"
        },
        {
            "src": "/login",
            "dest": "/login.php"
        },
        {
            "src": "/register",
            "dest": "/register.php"
        },
        {
            "src": "/logout",
            "dest": "/logout.php"
        },
        {
            "src": "/(.*).php",
            "dest": "/$1.php"
        }
    ]
}